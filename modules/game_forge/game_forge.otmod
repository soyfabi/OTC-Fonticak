Module
  name: game_forge
  description: game_forge
  author: game_forge
  website: game_forge
  scripts: [ game_forge_helpers.lua, game_forge.lua, game_forge_protocol.lua, forgeprotocol.lua ]
  sandboxed: false
  @onLoad: |
    initForgeProtocolBridge()
    ForgeController:init()
  @onUnload: |
    ForgeController:terminate()
    terminateForgeProtocolBridge()